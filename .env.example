# ═══════════════════════════════════════════════════════════
# 🔧 AI Chat Configuration
# ═══════════════════════════════════════════════════════════

# 🌐 BASE URL dari Google Colab (Cloudflare Tunnel URL)
# Ganti dengan URL yang diberikan oleh Google Colab setiap kali restart
# Contoh: https://xxxx-xxxx-xxxx.trycloudflare.com
BASE_URL=

# 🔑 API Key (default dari Colab notebook: sk-colab-local)
API_KEY=

# 🤖 Model name yang digunakan (sesuai mapping LiteLLM di Colab)
MODEL_NAME=

# 🌐 Port untuk web server lokal
PORT=3000
